---
import { FeatureGrid } from './FeatureGrid';
---

<section id="features" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">Capabilities</span>
      <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-3">
        Everything you need to automate your SOC
      </h2>
      <p class="text-sm text-text max-w-2xl mx-auto">
        Purpose-built for security teams who want real automation, not drag-and-drop toys.
      </p>
    </div>

    <FeatureGrid client:visible />

    <!-- Quick stats -->
    <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="text-center py-4">
        <div class="text-2xl font-bold text-heading">&lt; 5 min</div>
        <div class="text-xs text-muted mt-1">Setup Time</div>
      </div>
      <div class="text-center py-4">
        <div class="text-2xl font-bold text-heading">Pure Python</div>
        <div class="text-xs text-muted mt-1">Playbook Language</div>
      </div>
      <div class="text-center py-4">
        <div class="text-2xl font-bold text-heading">Async-First</div>
        <div class="text-xs text-muted mt-1">Parallel Execution</div>
      </div>
      <div class="text-center py-4">
        <div class="text-2xl font-bold text-heading">$0</div>
        <div class="text-xs text-muted mt-1">License Cost</div>
      </div>
    </div>
  </div>
</section>
