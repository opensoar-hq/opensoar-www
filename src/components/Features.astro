---
const features = [
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
    title: "Python-Native Playbooks",
    description: "Write automation in pure Python, not YAML or XML. Full IDE support with autocomplete, testing, and debugging. Deploy like any Python app.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4c0 1.5-.8 2.8-2 3.5v1h-4v-1c-1.2-.7-2-2-2-3.5a4 4 0 0 1 4-4z"/><path d="M10 10.5v2.5h4v-2.5"/><path d="M10 13c-2.67.5-5 2-5 4v1h14v-1c0-2-2.33-3.5-5-4"/><circle cx="12" cy="6" r="1"/></svg>`,
    title: "AI-Assisted Triage",
    description: "Auto-classify alerts, reduce noise by up to 90%, and surface what actually matters. LLM-powered analysis with human-in-the-loop controls.",
    badge: "Coming Soon",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 8h2m2 0h2m2 0h2"/><path d="M7 11h10"/></svg>`,
    title: "Integration Ecosystem",
    description: "CrowdStrike, SentinelOne, Jira, PagerDuty, Slack, and more. Community-driven integrations with a simple, consistent API.",
  },
  {
    icon: `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: "Real-Time Alert Ingestion",
    description: "Webhooks, polling, Elasticsearch, syslog &mdash; alerts flow in from anywhere. Playbooks fire automatically based on conditions you define.",
  },
];
---

<section id="features" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <span class="text-accent bg-accent/10 px-2 py-0.5 rounded font-medium text-xs">Capabilities</span>
      <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-3">
        Everything you need to automate your SOC
      </h2>
      <p class="text-sm text-text max-w-2xl mx-auto">
        Purpose-built for security teams who want real automation, not drag-and-drop toys.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {features.map((feature) => (
        <div class="group border border-border rounded-lg bg-surface p-6 hover:bg-surface-hover hover:border-accent/20 transition-all duration-200">
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-md bg-accent/10 text-accent mb-4 group-hover:bg-accent/15 transition-colors">
            <div set:html={feature.icon} />
          </div>

          <div class="flex items-center gap-2.5 mb-2">
            <h3 class="text-base font-semibold text-heading">{feature.title}</h3>
            {feature.badge && (
              <span class="text-accent bg-accent/10 px-2 py-0.5 rounded font-medium text-[11px]">
                {feature.badge}
              </span>
            )}
          </div>

          <p class="text-sm text-text leading-relaxed" set:html={feature.description} />
        </div>
      ))}
    </div>

    <!-- Quick stats -->
    <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="text-center py-4">
        <div class="text-2xl font-bold text-heading">< 5 min</div>
        <div class="text-xs text-muted mt-1">Setup Time</div>
      </div>
      <div class="text-center py-4">
        <div class="text-2xl font-bold text-heading">Pure Python</div>
        <div class="text-xs text-muted mt-1">Playbook Language</div>
      </div>
      <div class="text-center py-4">
        <div class="text-2xl font-bold text-heading">Async-First</div>
        <div class="text-xs text-muted mt-1">Parallel Execution</div>
      </div>
      <div class="text-center py-4">
        <div class="text-2xl font-bold text-heading">$0</div>
        <div class="text-xs text-muted mt-1">License Cost</div>
      </div>
    </div>
  </div>
</section>
