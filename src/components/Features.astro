---
import { AlertDemo } from './AlertDemo';

const features = [
  { icon: "code", label: "Python-Native Playbooks", desc: "Write automation in real Python — not YAML, not a sandbox. Full IDE support, any pip package.", tag: "Core" },
  { icon: "zap", label: "Real-Time Ingestion", desc: "Webhooks, polling, Elasticsearch, syslog — alerts flow in from anywhere and trigger playbooks automatically.", tag: "Core" },
  { icon: "layout", label: "SOC Dashboard", desc: "Priority queue, MTTR tracking, unassigned alerts, per-partner stats. Built for IR analysts.", tag: "UI" },
  { icon: "git-branch", label: "Async Playbook Engine", desc: "asyncio.gather() for parallel, await for sequential. Timeout, retry, and backoff per action.", tag: "Core" },
  { icon: "plug", label: "Integration Ecosystem", desc: "Elastic, CrowdStrike, VirusTotal, AbuseIPDB, Slack, Jira, and more. Community-driven.", tag: "Integrations" },
  { icon: "shield", label: "JWT + API Key Auth", desc: "Analyst management with JWT. API keys for integrations. Full REST API with OpenAPI docs.", tag: "Auth" },
  { icon: "layers", label: "Alert Lifecycle", desc: "New → In Progress → Resolved. Determination tracking, IOC extraction, deduplication, severity inference.", tag: "Core" },
  { icon: "cpu", label: "Celery Workers", desc: "Async playbook execution with horizontal scaling. Add more workers, handle more alerts.", tag: "Infra" },
];

const icons: Record<string, string> = {
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  zap: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>',
  layout: '<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
  "git-branch": '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  plug: '<path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a6 6 0 0 1-6 6 6 6 0 0 1-6-6V8z"/>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
  layers: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  cpu: '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/>',
};

const tagColors: Record<string, string> = {
  Core: "bg-[#e6edf3]/10 text-[#e6edf3]",
  UI: "bg-[#d29922]/10 text-[#d29922]",
  Integrations: "bg-[#3fb950]/10 text-[#3fb950]",
  Auth: "bg-[#f85149]/10 text-[#f85149]",
  Infra: "bg-[#848d97]/10 text-[#848d97]",
};
---

<section id="features" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">Capabilities</span>
      <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-3">
        Everything you need to automate your SOC
      </h2>
      <p class="text-sm text-text max-w-2xl mx-auto">
        Purpose-built for security teams who want real automation, not drag-and-drop toys.
      </p>
    </div>

    <!-- Feature list -->
    <div class="rounded-lg border border-border bg-surface overflow-hidden">
      <div class="flex items-center px-4 py-2.5 border-b border-border">
        <div class="flex items-center gap-1.5 mr-2">
          <div class="w-2.5 h-2.5 rounded-full bg-danger/50"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-warning/50"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-success/50"></div>
        </div>
        <span class="text-[11px] text-muted font-mono">opensoar — capabilities</span>
        <span class="ml-auto text-[11px] text-muted">{features.length} features</span>
      </div>

      <div class="divide-y divide-border">
        {features.map((f) => (
          <div class="flex items-start gap-3 px-4 py-3 hover:bg-surface-hover transition-colors">
            <div class="flex items-center justify-center w-8 h-8 rounded-md bg-heading/8 text-heading shrink-0 mt-0.5">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[f.icon]} />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-heading">{f.label}</span>
                <span class={`px-1.5 py-0.5 rounded text-[10px] font-medium ${tagColors[f.tag]}`}>{f.tag}</span>
              </div>
              <p class="text-xs text-text mt-0.5 leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Alert feed preview -->
    <div class="mt-12">
      <AlertDemo client:visible />
    </div>
  </div>
</section>
