---
---

<section id="features" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">Capabilities</span>
      <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-3">
        Everything you need to automate your SOC
      </h2>
      <p class="text-sm text-text max-w-2xl mx-auto">
        Purpose-built for security teams who want real automation, not drag-and-drop toys.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-6 gap-3">

      <!-- Python-Native Playbooks — wide card with code preview -->
      <div class="md:col-span-3 group rounded-lg border border-border bg-surface p-5 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <span class="text-xs font-medium text-heading">Python-Native Playbooks</span>
          <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-[#e6edf3]/10 text-[#e6edf3]">Core</span>
        </div>
        <p class="text-xs text-text leading-relaxed mb-4">Write automation in real Python — not YAML, not a sandbox. Full IDE support, any pip package.</p>
        <div class="rounded-md bg-bg border border-border overflow-hidden">
          <div class="flex items-center gap-1.5 px-3 py-1.5 border-b border-border">
            <div class="w-2 h-2 rounded-full bg-danger/40"></div>
            <div class="w-2 h-2 rounded-full bg-warning/40"></div>
            <div class="w-2 h-2 rounded-full bg-success/40"></div>
            <span class="text-[10px] text-muted font-mono ml-1">triage.py</span>
          </div>
          <pre class="px-3 py-2.5 text-[11px] leading-relaxed font-mono overflow-x-auto no-scrollbar"><code><span class="text-[#ff7b72]">@playbook</span>(<span class="text-[#a5d6ff]">"triage_critical"</span>)
<span class="text-[#ff7b72]">async def</span> <span class="text-[#d2a8ff]">run</span>(alert):
    iocs = <span class="text-[#ff7b72]">await</span> extract_iocs(alert)
    results = <span class="text-[#ff7b72]">await</span> gather(
        lookup_virustotal(iocs),
        check_abuseipdb(iocs),
    )
    <span class="text-[#ff7b72]">if</span> results.malicious:
        <span class="text-[#ff7b72]">await</span> escalate_to_slack(alert)</code></pre>
        </div>
      </div>

      <!-- Async Playbook Engine — wide card -->
      <div class="md:col-span-3 group rounded-lg border border-border bg-surface p-5 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>
            </svg>
          </div>
          <span class="text-xs font-medium text-heading">Async Playbook Engine</span>
          <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-[#e6edf3]/10 text-[#e6edf3]">Core</span>
        </div>
        <p class="text-xs text-text leading-relaxed mb-4">asyncio.gather() for parallel, await for sequential. Timeout, retry, and backoff per action.</p>
        <div class="rounded-md bg-bg border border-border overflow-hidden">
          <div class="flex items-center gap-1.5 px-3 py-1.5 border-b border-border">
            <div class="w-2 h-2 rounded-full bg-danger/40"></div>
            <div class="w-2 h-2 rounded-full bg-warning/40"></div>
            <div class="w-2 h-2 rounded-full bg-success/40"></div>
            <span class="text-[10px] text-muted font-mono ml-1">execution flow</span>
          </div>
          <div class="px-3 py-3 space-y-2">
            <div class="flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-success animate-pulse"></div>
              <span class="text-[11px] font-mono text-muted">alert received</span>
              <span class="text-[10px] text-muted/60 ml-auto">0ms</span>
            </div>
            <div class="flex items-center gap-2 ml-3">
              <div class="w-px h-3 bg-border -my-1"></div>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-warning"></div>
              <span class="text-[11px] font-mono text-heading">gather(</span>
            </div>
            <div class="flex items-center gap-2 ml-4">
              <div class="w-1.5 h-1.5 rounded-full bg-info/60"></div>
              <span class="text-[11px] font-mono text-muted">├─ virustotal.lookup()</span>
              <span class="text-[10px] text-muted/60 ml-auto">120ms</span>
            </div>
            <div class="flex items-center gap-2 ml-4">
              <div class="w-1.5 h-1.5 rounded-full bg-info/60"></div>
              <span class="text-[11px] font-mono text-muted">├─ abuseipdb.check()</span>
              <span class="text-[10px] text-muted/60 ml-auto">95ms</span>
            </div>
            <div class="flex items-center gap-2 ml-4">
              <div class="w-1.5 h-1.5 rounded-full bg-info/60"></div>
              <span class="text-[11px] font-mono text-muted">└─ geoip.resolve()</span>
              <span class="text-[10px] text-muted/60 ml-auto">45ms</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-warning"></div>
              <span class="text-[11px] font-mono text-heading">)</span>
              <span class="text-[10px] text-success ml-auto">parallel — 120ms total</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
              <span class="text-[11px] font-mono text-muted">await escalate()</span>
              <span class="text-[10px] text-muted/60 ml-auto">200ms</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Real-Time Ingestion -->
      <div class="md:col-span-2 group rounded-lg border border-border bg-surface p-5 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <span class="text-xs font-medium text-heading">Real-Time Ingestion</span>
        </div>
        <p class="text-xs text-text leading-relaxed mb-4">Webhooks, polling, Elasticsearch, syslog — alerts flow in from anywhere.</p>
        <div class="space-y-1.5">
          <div class="flex items-center gap-2 text-[11px] font-mono">
            <span class="text-success">POST</span>
            <span class="text-muted">/webhooks/alerts</span>
          </div>
          <div class="flex items-center gap-2 text-[11px] font-mono">
            <span class="text-warning">POLL</span>
            <span class="text-muted">elasticsearch:9200</span>
          </div>
          <div class="flex items-center gap-2 text-[11px] font-mono">
            <span class="text-info">TCP</span>
            <span class="text-muted">syslog:514</span>
          </div>
        </div>
      </div>

      <!-- SOC Dashboard -->
      <div class="md:col-span-2 group rounded-lg border border-border bg-surface p-5 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
            </svg>
          </div>
          <span class="text-xs font-medium text-heading">SOC Dashboard</span>
        </div>
        <p class="text-xs text-text leading-relaxed mb-4">Priority queue, MTTR tracking, unassigned alerts, per-partner stats.</p>
        <div class="grid grid-cols-2 gap-2">
          <div class="rounded-md bg-bg border border-border px-2.5 py-2 text-center">
            <div class="text-base font-bold text-heading">24</div>
            <div class="text-[10px] text-muted">Open</div>
          </div>
          <div class="rounded-md bg-bg border border-border px-2.5 py-2 text-center">
            <div class="text-base font-bold text-success">4.2m</div>
            <div class="text-[10px] text-muted">MTTR</div>
          </div>
          <div class="rounded-md bg-bg border border-border px-2.5 py-2 text-center">
            <div class="text-base font-bold text-warning">7</div>
            <div class="text-[10px] text-muted">Critical</div>
          </div>
          <div class="rounded-md bg-bg border border-border px-2.5 py-2 text-center">
            <div class="text-base font-bold text-heading">156</div>
            <div class="text-[10px] text-muted">Today</div>
          </div>
        </div>
      </div>

      <!-- Integration Ecosystem -->
      <div class="md:col-span-2 group rounded-lg border border-border bg-surface p-5 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a6 6 0 0 1-6 6 6 6 0 0 1-6-6V8z"/>
            </svg>
          </div>
          <span class="text-xs font-medium text-heading">Integrations</span>
        </div>
        <p class="text-xs text-text leading-relaxed mb-3">All integrations are open source. Contribute your own or use what's built.</p>
        <div class="flex flex-wrap gap-1.5">
          {[
            { name: "Elastic", path: "elastic" },
            { name: "VirusTotal", path: "virustotal" },
            { name: "AbuseIPDB", path: "abuseipdb" },
            { name: "Slack", path: "slack" },
            { name: "Email", path: "email" },
          ].map(i => (
            <a href={`https://github.com/opensoar-hq/opensoar-core/tree/main/src/opensoar/integrations/${i.path}`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-2 py-1 rounded-md bg-bg border border-border text-[10px] font-mono text-muted hover:text-heading hover:border-heading/30 transition-colors">
              <svg class="w-2.5 h-2.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              {i.name}
            </a>
          ))}
          {["CrowdStrike", "Jira", "PagerDuty"].map(name => (
            <span class="px-2 py-1 rounded-md bg-bg border border-border/50 text-[10px] font-mono text-muted/40">{name} <span class="text-[9px] italic">soon</span></span>
          ))}
        </div>
      </div>

      <!-- Alert Lifecycle — wider -->
      <div class="md:col-span-3 group rounded-lg border border-border bg-surface p-5 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>
            </svg>
          </div>
          <span class="text-xs font-medium text-heading">Alert Lifecycle</span>
          <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-[#e6edf3]/10 text-[#e6edf3]">Core</span>
        </div>
        <p class="text-xs text-text leading-relaxed mb-4">Full lifecycle management with determination tracking, IOC extraction, and deduplication.</p>
        <div class="flex items-center gap-0 text-[11px] font-mono">
          <span class="px-2.5 py-1 rounded-l-md bg-warning/15 text-warning border border-warning/20">New</span>
          <svg class="w-4 h-4 text-muted/40 -mx-0.5 relative z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          <span class="px-2.5 py-1 bg-info/15 text-info border border-info/20">In Progress</span>
          <svg class="w-4 h-4 text-muted/40 -mx-0.5 relative z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          <span class="px-2.5 py-1 rounded-r-md bg-success/15 text-success border border-success/20">Resolved</span>
        </div>
      </div>

      <!-- Auth + Workers combined -->
      <div class="md:col-span-3 group rounded-lg border border-border bg-surface p-5 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            </svg>
          </div>
          <span class="text-xs font-medium text-heading">Auth & Scaling</span>
        </div>
        <p class="text-xs text-text leading-relaxed mb-4">JWT analyst auth, API keys for integrations, Celery workers for horizontal scaling.</p>
        <div class="space-y-1.5">
          <div class="flex items-center gap-2 text-[11px] font-mono">
            <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
            <span class="text-muted">worker-01</span>
            <span class="text-muted/60 ml-auto">12 runs/min</span>
          </div>
          <div class="flex items-center gap-2 text-[11px] font-mono">
            <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
            <span class="text-muted">worker-02</span>
            <span class="text-muted/60 ml-auto">9 runs/min</span>
          </div>
          <div class="flex items-center gap-2 text-[11px] font-mono">
            <span class="w-1.5 h-1.5 rounded-full bg-warning animate-pulse"></span>
            <span class="text-muted">worker-03</span>
            <span class="text-muted/60 ml-auto">scaling up…</span>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>
