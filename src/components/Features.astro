---
const features = [
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
    title: "Python-Native Playbooks",
    description: "Write automation in pure Python, not YAML or XML. Full IDE support with autocomplete, testing, and debugging. Deploy like any Python app.",
    gradient: "from-accent-blue to-accent-cyan",
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4c0 1.5-.8 2.8-2 3.5v1h-4v-1c-1.2-.7-2-2-2-3.5a4 4 0 0 1 4-4z"/><path d="M10 10.5v2.5h4v-2.5"/><path d="M10 13c-2.67.5-5 2-5 4v1h14v-1c0-2-2.33-3.5-5-4"/><circle cx="12" cy="6" r="1"/></svg>`,
    title: "AI-Assisted Triage",
    description: "Auto-classify alerts, reduce noise by up to 90%, and surface what actually matters. LLM-powered analysis with human-in-the-loop controls.",
    gradient: "from-accent-purple to-pink-500",
    badge: "Coming Soon",
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 8h2m2 0h2m2 0h2"/><path d="M7 11h10"/></svg>`,
    title: "Integration Ecosystem",
    description: "CrowdStrike, SentinelOne, Jira, PagerDuty, Slack, and more. Community-driven integrations with a simple, consistent API.",
    gradient: "from-accent-cyan to-emerald-400",
  },
  {
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: "Real-Time Alert Ingestion",
    description: "Webhooks, polling, Elasticsearch, syslog &mdash; alerts flow in from anywhere. Playbooks fire automatically based on conditions you define.",
    gradient: "from-yellow-400 to-orange-500",
  },
];
---

<section id="features" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold text-accent-blue uppercase tracking-widest mb-3">Capabilities</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Everything you need to automate your SOC
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        Purpose-built for security teams who want real automation, not drag-and-drop toys.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {features.map((feature) => (
        <div class="group relative rounded-2xl border border-white/5 bg-navy-900/50 p-8 hover:border-white/10 hover:bg-navy-900/80 transition-all duration-300">
          <!-- Gradient glow on hover -->
          <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br ${feature.gradient} opacity-0 group-hover:opacity-[0.03] transition-opacity duration-300`}></div>

          <div class="relative">
            <div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br ${feature.gradient} mb-5`}>
              <div class="text-white" set:html={feature.icon} />
            </div>

            <div class="flex items-center gap-3 mb-3">
              <h3 class="text-xl font-semibold text-white">{feature.title}</h3>
              {feature.badge && (
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent-purple/10 text-accent-purple border border-accent-purple/20">
                  {feature.badge}
                </span>
              )}
            </div>

            <p class="text-slate-400 leading-relaxed" set:html={feature.description} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
