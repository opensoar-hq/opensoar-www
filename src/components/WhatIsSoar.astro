---
import { SoarOrbital } from './SoarOrbital';
---

<section id="what-is-soar" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid lg:grid-cols-2 gap-14 items-center">
      <!-- Left: Punchy explainer -->
      <div>
        <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">What is SOAR?</span>
        <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-4">
          Security Orchestration,<br/>Automation &amp; Response
        </h2>
        <p class="text-sm text-text leading-relaxed mb-6">
          Your SOC drowns in 960+ alerts a day. <strong class="text-heading">SOAR</strong> automates the repetitive work &mdash; alert triage, IOC enrichment, ticket creation, escalation &mdash; so analysts focus on real threats while playbooks handle the rest at machine speed.
        </p>
        <p class="text-sm text-text leading-relaxed">
          Tools like Splunk SOAR and XSOAR cost six figures, lock you into YAML, and charge per automation action.
          <strong class="text-heading" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.02em;"><span style="font-weight: 400;"> Open</span><span style="font-weight: 700;">SOAR</span></strong> gives you the same capabilities in pure Python &mdash; no sandbox, no per-action billing, Apache 2.0 licensed.
        </p>
      </div>

      <!-- Right: Orbital visualization — alert sources flowing into SOAR engine -->
      <div class="hidden lg:flex items-center justify-center">
        <SoarOrbital client:visible />
      </div>
    </div>
  </div>
</section>
