---
---

<section class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="relative rounded-2xl border border-white/5 bg-gradient-to-br from-navy-800/80 to-navy-900/80 overflow-hidden">
      <!-- Background gradient -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute -top-20 -right-20 w-[400px] h-[400px] bg-accent-blue/5 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-[300px] h-[300px] bg-accent-purple/5 rounded-full blur-3xl"></div>
      </div>

      <div class="relative px-8 py-16 md:px-16 md:py-20 text-center">
        <!-- Icon -->
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-accent-blue/20 to-accent-purple/20 border border-white/10 mb-8">
          <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
            <path d="M2 12h20"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Truly Open Source
        </h2>

        <p class="text-lg text-slate-400 max-w-2xl mx-auto mb-8 leading-relaxed">
          Apache 2.0 licensed. No "open core" tricks, no enterprise-only features behind a paywall.
          Self-host on your infrastructure, own your data, contribute to the community.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://github.com/opensoar-hq"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2.5 px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white font-medium hover:bg-white/10 transition-all"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Star on GitHub
            <svg class="w-4 h-4 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </a>
        </div>

        <!-- Stats row -->
        <div class="flex items-center justify-center gap-8 md:gap-16 mt-12 pt-8 border-t border-white/5">
          <div class="text-center">
            <div class="text-2xl font-bold text-white">Apache 2.0</div>
            <div class="text-sm text-slate-500 mt-1">License</div>
          </div>
          <div class="w-px h-10 bg-white/5"></div>
          <div class="text-center">
            <div class="text-2xl font-bold text-white">Python</div>
            <div class="text-sm text-slate-500 mt-1">Backend</div>
          </div>
          <div class="w-px h-10 bg-white/5"></div>
          <div class="text-center">
            <div class="text-2xl font-bold text-white">100%</div>
            <div class="text-sm text-slate-500 mt-1">Self-Hosted</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
