---
import { AlertDemo } from './AlertDemo';
---

<section class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">Philosophy</span>
      <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-3">
        Built by engineers who've been on-call at 3am
      </h2>
      <p class="text-sm text-text max-w-2xl mx-auto">
        We're not reinventing the wheel with another low-code builder. We're giving security teams the tools they already know.
      </p>
    </div>

    <!-- Differentiators grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8">
      <div class="rounded-lg border border-border bg-surface p-5">
        <div class="flex items-center gap-2.5 mb-2">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-heading">Python, not YAML</span>
        </div>
        <p class="text-xs text-text leading-relaxed">Real code, real IDE, real debugging. Write playbooks with the full power of Python — breakpoints, type hints, unit tests. Not a proprietary DSL.</p>
      </div>

      <div class="rounded-lg border border-border bg-surface p-5">
        <div class="flex items-center gap-2.5 mb-2">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-heading">No drag-and-drop</span>
        </div>
        <p class="text-xs text-text leading-relaxed">asyncio.gather() beats visual flowcharts at scale. Parallel execution, error handling, retries — all native Python patterns you already know.</p>
      </div>

      <div class="rounded-lg border border-border bg-surface p-5">
        <div class="flex items-center gap-2.5 mb-2">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-heading">Own your data</span>
        </div>
        <p class="text-xs text-text leading-relaxed">Self-hosted on your infrastructure. Apache 2.0 licensed. No feature gates, no usage limits, no vendor lock-in. Your alerts stay yours.</p>
      </div>

      <div class="rounded-lg border border-border bg-surface p-5">
        <div class="flex items-center gap-2.5 mb-2">
          <div class="flex items-center justify-center w-7 h-7 rounded-md bg-heading/8 text-heading">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-heading">Built for analysts</span>
        </div>
        <p class="text-xs text-text leading-relaxed">By engineers who understand the IR workflow. Purpose-built for security teams who are tired of duct-taping YAML configs at 3am during an incident.</p>
      </div>
    </div>

    <!-- Alert feed showing the workflow in action -->
    <AlertDemo client:visible />
  </div>
</section>
