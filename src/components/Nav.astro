</div>

<style>
  .nav-dropdown:hover .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
  }
</style>

<script>
  const nav = document.getElementById('main-nav');
  const inner = document.getElementById('nav-inner');
  const divider = document.getElementById('nav-divider');
  const divider2 = document.getElementById('nav-divider-2');

  if (nav && inner) {
    let lastScrolled = false;
    const updateNav = () => {
      const scrolled = window.scrollY > 40;
      if (scrolled === lastScrolled) return;
      lastScrolled = scrolled;
      nav.style.paddingTop = scrolled ? '0.5rem' : '1rem';
      inner.style.backgroundColor = scrolled ? '#161b22' : 'transparent';
      inner.style.borderColor = scrolled ? '#30363d' : 'transparent';
      if (divider) divider.style.backgroundColor = scrolled ? '#30363d' : 'transparent';
      if (divider2) divider2.style.backgroundColor = scrolled ? '#30363d' : 'transparent';
    };
    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();
  }

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = '<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>';
  const closeIcon = '<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

  function openMobileMenu() {
    if (!mobileMenu || !menuBtn) return;
    mobileMenu.classList.remove('invisible');
    mobileMenu.classList.remove('opacity-0');
    mobileMenu.classList.add('opacity-100');
    mobileMenu.setAttribute('aria-hidden', 'false');
    menuBtn.innerHTML = closeIcon;
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    if (!mobileMenu || !menuBtn) return;
    mobileMenu.classList.add('opacity-0');
    mobileMenu.classList.remove('opacity-100');
    mobileMenu.setAttribute('aria-hidden', 'true');
    menuBtn.innerHTML = hamburgerIcon;
    document.body.style.overflow = '';
    setTimeout(() => { mobileMenu.classList.add('invisible'); }, 200);
  }

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('invisible');
      isOpen ? closeMobileMenu() : openMobileMenu();
    });

    // Close on link click
    mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => closeMobileMenu());
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('invisible')) {
        closeMobileMenu();
      }
    });
  }
</script>
