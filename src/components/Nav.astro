---
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 flex justify-center pt-4 transition-[padding] duration-300">
  <div id="nav-inner" class="flex items-center gap-1 px-2 h-10 rounded-lg border border-transparent transition-all duration-300">
    <a href="/" class="flex items-center gap-2 px-3">
      <svg class="w-4 h-4 text-heading" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
        <path d="m9 12 2 2 4-4"/>
      </svg>
      <span class="text-sm text-heading" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.03em;"><span style="font-weight: 400;">Open</span><span style="font-weight: 700;">SOAR</span></span>
      <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-warning/15 text-warning leading-none">Beta</span>
    </a>

    <div id="nav-divider" class="w-px h-4 transition-colors duration-300" style="background-color: transparent;"></div>

    <div class="hidden md:flex items-center gap-0.5 text-[13px]">
      <a href="#features" class="nav-link px-2.5 py-1 rounded-md text-text hover:text-heading transition-colors duration-150">Features</a>
      <a href="#playbooks" class="nav-link px-2.5 py-1 rounded-md text-text hover:text-heading transition-colors duration-150">Playbooks</a>
      <a href="#ai" class="nav-link px-2.5 py-1 rounded-md text-text hover:text-heading transition-colors duration-150">AI</a>
      <a href="#compare" class="nav-link px-2.5 py-1 rounded-md text-text hover:text-heading transition-colors duration-150">Compare</a>
    </div>

    <div id="nav-divider-2" class="hidden md:block w-px h-4 transition-colors duration-300" style="background-color: transparent;"></div>

    <a
      href="https://github.com/opensoar-hq/opensoar-core"
      target="_blank"
      rel="noopener"
      class="hidden md:inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-md bg-heading text-bg hover:bg-heading/90 transition-colors"
    >
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
      GitHub
    </a>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const inner = document.getElementById('nav-inner');
  const divider = document.getElementById('nav-divider');
  const divider2 = document.getElementById('nav-divider-2');
  const links = document.querySelectorAll('.nav-link[href^="#"]');

  if (nav && inner) {
    let lastScrolled = false;

    const updateNav = () => {
      const scrolled = window.scrollY > 40;
      if (scrolled === lastScrolled) return;
      lastScrolled = scrolled;

      nav.style.paddingTop = scrolled ? '0.5rem' : '1rem';
      inner.style.backgroundColor = scrolled ? '#161b22' : 'transparent';
      inner.style.borderColor = scrolled ? '#30363d' : 'transparent';
      if (divider) divider.style.backgroundColor = scrolled ? '#30363d' : 'transparent';
      if (divider2) divider2.style.backgroundColor = scrolled ? '#30363d' : 'transparent';
    };

    const sections = Array.from(links).map(link => {
      const id = link.getAttribute('href')!.slice(1);
      return { link, el: document.getElementById(id) };
    }).filter(s => s.el);

    const updateActive = () => {
      const scrollY = window.scrollY + 120;
      let activeLink = null;
      for (const { link, el } of sections) {
        if (el && el.offsetTop <= scrollY) activeLink = link;
      }
      links.forEach(link => {
        const isActive = link === activeLink;
        link.classList.toggle('text-heading', isActive);
        link.classList.toggle('text-text', !isActive);
        (link as HTMLElement).style.backgroundColor = isActive ? 'rgba(230, 237, 243, 0.06)' : '';
      });
    };

    const onScroll = () => { updateNav(); updateActive(); };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
