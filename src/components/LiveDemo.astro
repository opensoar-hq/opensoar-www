---
import { AlertDemo } from './AlertDemo';
---

<section id="demo" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-10">
      <span class="text-accent bg-accent/10 px-2 py-0.5 rounded font-medium text-xs">Interactive Demo</span>
      <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-3">
        See it in action
      </h2>
      <p class="text-sm text-text max-w-2xl mx-auto">
        Click any alert to expand it. Search, filter by severity &mdash; this is what your SOC dashboard looks like out of the box.
      </p>
    </div>

    <div class="mx-auto max-w-4xl">
      <AlertDemo client:visible />
    </div>
  </div>
</section>
