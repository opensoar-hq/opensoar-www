---
import { AlertDemo } from './AlertDemo';
---

<section id="demo" class="relative pt-8 pb-0 md:pt-10 md:pb-0 bg-[linear-gradient(180deg,var(--color-bg)_0%,var(--color-bg)_56%,#dfe5eb_88%,#eef2f6_100%)]">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 h-64 bg-[radial-gradient(ellipse_at_bottom,rgba(255,255,255,0.45),rgba(244,247,250,0.18)_28%,rgba(13,17,23,0)_72%)]"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 h-44 bg-gradient-to-b from-transparent via-[rgba(244,247,250,0.28)] to-[rgba(255,255,255,0.55)]"
  ></div>
  <div class="mx-auto max-w-6xl px-6">
    <AlertDemo client:visible />
  </div>
</section>
