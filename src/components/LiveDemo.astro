---
import { AlertDemo } from './AlertDemo';
---

<section id="demo" class="relative pt-4 pb-14 md:pt-6 md:pb-20 bg-[linear-gradient(180deg,var(--color-bg)_0%,var(--color-bg)_42%,rgba(255,255,255,0.03)_64%,rgba(255,255,255,0.07)_84%,rgba(255,255,255,0.10)_100%)]">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 bottom-0 z-0 h-80 w-[170%] -translate-x-1/2 rounded-[999px] bg-[radial-gradient(ellipse_at_center,rgba(255,255,255,0.14),rgba(255,255,255,0.06)_38%,rgba(13,17,23,0)_78%)] blur-3xl"
  ></div>
  <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 pt-2 md:pt-3">
    <div class="relative">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-[6%] right-[6%] -bottom-10 z-0 h-24 rounded-t-[28px] bg-[linear-gradient(180deg,rgba(255,255,255,0.16)_0%,rgba(255,255,255,0.09)_28%,rgba(255,255,255,0.03)_56%,rgba(13,17,23,0)_100%)] md:-bottom-12 md:h-28 md:rounded-t-[40px]"
      ></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-[22%] right-[22%] -bottom-3 z-10 h-6 rounded-[999px] bg-black/8 blur-2xl"
      ></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -bottom-5 left-3 z-10 h-14 w-28 rounded-full bg-black/20 blur-[28px] sm:left-8 sm:h-16 sm:w-40 md:left-12 md:h-20 md:w-52"
      ></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -bottom-5 right-3 z-10 h-14 w-28 rounded-full bg-black/20 blur-[28px] sm:right-8 sm:h-16 sm:w-40 md:right-12 md:h-20 md:w-52"
      ></div>
      <div class="relative z-20">
        <AlertDemo client:visible />
      </div>
    </div>
  </div>
</section>
