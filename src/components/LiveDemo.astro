---
import { AlertDemo } from './AlertDemo';
---

<section id="demo" class="relative pt-14 pb-8 md:pt-18 md:pb-10">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 h-56 bg-[radial-gradient(ellipse_at_bottom,rgba(230,237,243,0.22),rgba(230,237,243,0.08)_28%,rgba(13,17,23,0)_72%)]"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent via-[#11161d]/70 to-[#151b24]"
  ></div>
  <div class="mx-auto max-w-6xl px-6">
    <AlertDemo client:visible />
  </div>
</section>
