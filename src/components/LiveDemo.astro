---
import { AlertDemo } from './AlertDemo';
---

<section id="demo" class="relative pt-6 pb-10 md:pt-8 md:pb-16 bg-[linear-gradient(180deg,var(--color-bg)_0%,var(--color-bg)_44%,rgba(255,255,255,0.03)_66%,rgba(255,255,255,0.07)_86%,rgba(255,255,255,0.10)_100%)]">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 bottom-0 z-0 h-80 w-[170%] -translate-x-1/2 rounded-[999px] bg-[radial-gradient(ellipse_at_center,rgba(255,255,255,0.14),rgba(255,255,255,0.06)_38%,rgba(13,17,23,0)_78%)] blur-3xl"
  ></div>
  <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 pt-3 md:pt-4">
    <div class="relative">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-6 right-6 -bottom-4 h-10 rounded-[999px] bg-black/35 blur-2xl sm:left-12 sm:right-12 md:left-20 md:right-20"
      ></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -bottom-3 left-0 h-16 w-14 rounded-full bg-black/20 blur-xl sm:w-20 md:w-28"
      ></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -bottom-3 right-0 h-16 w-14 rounded-full bg-black/20 blur-xl sm:w-20 md:w-28"
      ></div>
      <AlertDemo client:visible />
    </div>
  </div>
</section>
