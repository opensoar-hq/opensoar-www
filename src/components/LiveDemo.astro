---
import { AlertDemo } from './AlertDemo';
---

<section id="demo" class="relative pt-8 pb-0 md:pt-10 md:pb-0 bg-[linear-gradient(180deg,var(--color-bg)_0%,var(--color-bg)_42%,rgba(255,255,255,0.03)_64%,rgba(255,255,255,0.07)_84%,rgba(255,255,255,0.10)_100%)]">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 bottom-0 z-0 h-80 w-[170%] -translate-x-1/2 rounded-[999px] bg-[radial-gradient(ellipse_at_center,rgba(255,255,255,0.14),rgba(255,255,255,0.06)_38%,rgba(13,17,23,0)_78%)] blur-3xl"
  ></div>
  <div class="relative z-10 mx-auto max-w-6xl px-6 pt-4 md:pt-6">
    <AlertDemo client:visible />
  </div>
</section>
