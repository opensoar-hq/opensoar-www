---
import { AlertDemo } from './AlertDemo';
---

<section id="demo" class="relative pt-8 pb-0 md:pt-10 md:pb-0 bg-[linear-gradient(180deg,var(--color-bg)_0%,var(--color-bg)_38%,rgba(255,255,255,0.04)_62%,rgba(255,255,255,0.08)_82%,rgba(255,255,255,0.12)_100%)]">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 z-0 h-72 bg-[radial-gradient(ellipse_at_bottom,rgba(255,255,255,0.18),rgba(255,255,255,0.10)_30%,rgba(13,17,23,0)_74%)]"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 z-0 h-52 bg-gradient-to-b from-transparent via-[rgba(255,255,255,0.06)] to-[rgba(255,255,255,0.14)]"
  ></div>
  <div class="relative z-10 mx-auto max-w-6xl px-6 pt-4 md:pt-6">
    <AlertDemo client:visible />
  </div>
</section>
