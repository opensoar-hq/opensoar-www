---
---

<section class="relative pt-28 pb-20 md:pt-36 md:pb-28 overflow-hidden">
  <!-- Floating shapes background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Subtle gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] via-transparent to-white/[0.02] blur-3xl"></div>

    <!-- Shape 1 — large, top-left -->
    <div class="hero-shape absolute left-[-8%] top-[12%] opacity-0" style="--delay: 0.2s; --float-duration: 14s;">
      <div class="w-[500px] h-[120px] rounded-full rotate-12 bg-gradient-to-r from-white/[0.07] to-transparent backdrop-blur-[2px] border border-white/[0.08] shadow-[0_8px_32px_0_rgba(255,255,255,0.05)]"></div>
    </div>

    <!-- Shape 2 — medium, top-right -->
    <div class="hero-shape absolute right-[-3%] top-[8%] opacity-0" style="--delay: 0.5s; --float-duration: 16s;">
      <div class="w-[300px] h-[70px] rounded-full -rotate-[20deg] bg-gradient-to-r from-white/[0.06] to-transparent backdrop-blur-[2px] border border-white/[0.06] shadow-[0_8px_32px_0_rgba(255,255,255,0.04)]"></div>
    </div>

    <!-- Shape 3 — large, bottom-right -->
    <div class="hero-shape absolute right-[-5%] bottom-[10%] opacity-0" style="--delay: 0.4s; --float-duration: 18s;">
      <div class="w-[450px] h-[110px] rounded-full -rotate-[15deg] bg-gradient-to-r from-white/[0.06] to-transparent backdrop-blur-[2px] border border-white/[0.07] shadow-[0_8px_32px_0_rgba(255,255,255,0.04)]"></div>
    </div>

    <!-- Shape 4 — small, left-center -->
    <div class="hero-shape absolute left-[8%] bottom-[18%] opacity-0" style="--delay: 0.7s; --float-duration: 12s;">
      <div class="w-[200px] h-[50px] rounded-full rotate-[8deg] bg-gradient-to-r from-white/[0.05] to-transparent backdrop-blur-[2px] border border-white/[0.06]"></div>
    </div>

    <!-- Shape 5 — tiny, top-center -->
    <div class="hero-shape absolute left-[30%] top-[5%] opacity-0" style="--delay: 0.9s; --float-duration: 10s;">
      <div class="w-[140px] h-[35px] rounded-full -rotate-[25deg] bg-gradient-to-r from-white/[0.04] to-transparent backdrop-blur-[1px] border border-white/[0.05]"></div>
    </div>

    <!-- Shape 6 — medium, right-center -->
    <div class="hero-shape absolute right-[12%] top-[45%] opacity-0" style="--delay: 0.6s; --float-duration: 15s;">
      <div class="w-[250px] h-[60px] rounded-full rotate-[18deg] bg-gradient-to-r from-white/[0.05] to-transparent backdrop-blur-[1px] border border-white/[0.06]"></div>
    </div>
  </div>

  <!-- Fade edges -->
  <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-bg/60 pointer-events-none"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
      Apache 2.0 Licensed &mdash; Free &amp; Open Source
    </div>

    <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-heading leading-tight tracking-tight mb-5">
      Open-Source SOAR for<br/>
      <span class="text-heading">Modern Security Teams</span>
    </h1>

    <p class="text-base md:text-lg text-text max-w-2xl mx-auto mb-10 leading-relaxed">
      Python-native playbooks. AI-assisted triage. Real-time alert ingestion.
      Build your security automation the way it should be &mdash; in code, not YAML.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a
        href="https://github.com/opensoar-hq"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-heading text-bg font-medium text-sm hover:bg-heading/90 transition-colors"
      >
        <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Get Started
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <a
        href="https://demo.opensoar.app"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-surface border border-border text-heading font-medium text-sm hover:bg-surface-hover transition-colors"
      >
        <svg class="w-4 h-4 text-heading" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>
        </svg>
        Live Demo
      </a>
    </div>

    <!-- Terminal preview -->
    <div class="mt-14 mx-auto max-w-2xl">
      <div class="rounded-lg border border-border bg-surface/80 backdrop-blur-sm overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border">
          <div class="w-2.5 h-2.5 rounded-full bg-danger/50"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-warning/50"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-success/50"></div>
          <span class="ml-2 text-[11px] text-muted font-mono">terminal — 4 commands to production</span>
        </div>
        <div class="p-4 font-mono text-xs text-left text-text leading-loose">
          <div class="flex items-start gap-2">
            <span class="text-heading select-none">$</span>
            <span>git clone https://github.com/opensoar-hq/opensoar-deploy</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-heading select-none">$</span>
            <span>cd opensoar-deploy && cp .env.example .env</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-heading select-none">$</span>
            <span>docker compose up -d</span>
          </div>
          <div class="mt-2 pl-4 border-l-2 border-success/30 space-y-0.5">
            <div><span class="text-success">&#10003;</span> PostgreSQL + Redis ready</div>
            <div><span class="text-success">&#10003;</span> API running on <span class="text-heading">:8000</span></div>
            <div><span class="text-success">&#10003;</span> Dashboard ready at <span class="text-heading">:3000</span></div>
            <div><span class="text-success">&#10003;</span> 3 example playbooks loaded</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes hero-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(15px); }
  }

  @keyframes hero-fade-in {
    from {
      opacity: 0;
      transform: translateY(-40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-shape {
    animation:
      hero-fade-in 1.8s cubic-bezier(0.23, 0.86, 0.39, 0.96) var(--delay, 0s) forwards,
      hero-float var(--float-duration, 14s) ease-in-out var(--delay, 0s) infinite;
  }
</style>
