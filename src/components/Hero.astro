---
import { FlickeringGrid } from './ui/flickering-grid';
---

<section class="relative pt-28 pb-20 md:pt-36 md:pb-28 overflow-hidden">
  <!-- Flickering grid background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <FlickeringGrid
      client:visible
      className="z-0 absolute inset-0 size-full"
      squareSize={4}
      gridGap={6}
      color="#6B7280"
      maxOpacity={0.15}
      flickerChance={0.1}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-bg/80"></div>
  </div>
  <div class="relative z-10 mx-auto max-w-6xl px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
      Apache 2.0 Licensed &mdash; Free &amp; Open Source
    </div>

    <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-heading leading-tight tracking-tight mb-5">
      Open-Source SOAR for<br/>
      <span class="text-heading">Modern Security Teams</span>
    </h1>

    <p class="text-base md:text-lg text-text max-w-2xl mx-auto mb-10 leading-relaxed">
      Python-native playbooks. AI-assisted triage. Real-time alert ingestion.
      Build your security automation the way it should be &mdash; in code, not YAML.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a
        href="https://github.com/opensoar-hq/opensoar-core"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-heading text-bg font-medium text-sm hover:bg-heading/90 transition-colors"
      >
        <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Get Started
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      <a
        href="https://demo.opensoar.app"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-surface border border-border text-heading font-medium text-sm hover:bg-surface-hover transition-colors"
      >
        <svg class="w-4 h-4 text-heading" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>
        </svg>
        Live Demo
      </a>
    </div>

    <!-- Quick start command -->
    <div class="mt-14 mx-auto max-w-md">
      <div class="flex items-center gap-3 bg-surface border border-border rounded-lg px-4 py-3">
        <span class="text-muted select-none">$</span>
        <code class="text-sm text-heading font-mono flex-1 select-all">git clone https://github.com/opensoar-hq/opensoar-core && cd opensoar-core && docker compose up -d</code>
        <button
          id="copy-cmd"
          class="text-muted hover:text-heading transition-colors shrink-0"
          aria-label="Copy command"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
        </button>
      </div>
    </div>

    <script>
      document.getElementById('copy-cmd')?.addEventListener('click', (e) => {
        const cmd = 'git clone https://github.com/opensoar-hq/opensoar-core && cd opensoar-core && docker compose up -d';
        navigator.clipboard.writeText(cmd);
        const btn = e.currentTarget as HTMLButtonElement;
        btn.innerHTML = '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => {
          btn.innerHTML = '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        }, 2000);
      });
    </script>
  </div>
</section>
