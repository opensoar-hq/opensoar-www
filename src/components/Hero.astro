---
import { FlickeringGrid } from './ui/flickering-grid';
---

<section class="relative pt-28 pb-20 md:pt-36 md:pb-28 overflow-hidden">
  <!-- Flickering grid background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <FlickeringGrid
      client:visible
      className="z-0 absolute inset-0 size-full"
      squareSize={4}
      gridGap={6}
      color="#6B7280"
      maxOpacity={0.15}
      flickerChance={0.1}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-bg/80"></div>
  </div>
  <div class="relative z-10 mx-auto max-w-6xl px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
      Apache 2.0 Licensed &mdash; Free &amp; Open Source
    </div>

    <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-heading leading-tight tracking-tight mb-5">
      Open-Source SOAR for<br/>
      <span class="text-heading">Modern Security Teams</span>
    </h1>

    <p class="text-base md:text-lg text-text max-w-2xl mx-auto mb-10 leading-relaxed">
      Python-native playbooks. AI-assisted triage. Real-time alert ingestion.
      Build your security automation the way it should be &mdash; in code, not YAML.
    </p>

    <!-- Install + GitHub row -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mt-2">
      <div class="flex items-center gap-3 bg-surface border border-border rounded-lg pl-4 pr-2 py-2.5">
        <span class="text-xs text-muted whitespace-nowrap shrink-0">Get started</span>
        <div class="w-px h-4 bg-border shrink-0"></div>
        <span class="text-muted select-none shrink-0 text-sm font-mono">$</span>
        <code class="text-sm text-heading font-mono whitespace-nowrap">curl -fsSL https://opensoar.app/install.sh | sh</code>
        <button
          id="copy-cmd"
          class="text-muted hover:text-heading transition-colors shrink-0 p-1 rounded hover:bg-heading/10"
          aria-label="Copy install command"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
        </button>
      </div>

      <button
        id="copy-cmd-btn"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-heading text-bg font-medium text-sm hover:bg-heading/90 transition-colors cursor-pointer border-none"
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <span id="copy-cmd-text">Copy</span>
      </button>
    </div>

    <script>
      const cmd = 'curl -fsSL https://opensoar.app/install.sh | sh';

      // Inline copy icon
      document.getElementById('copy-cmd')?.addEventListener('click', (e) => {
        navigator.clipboard.writeText(cmd);
        const btn = e.currentTarget as HTMLButtonElement;
        btn.innerHTML = '<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => {
          btn.innerHTML = '<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        }, 2000);
      });

      // Primary copy button
      document.getElementById('copy-cmd-btn')?.addEventListener('click', () => {
        navigator.clipboard.writeText(cmd);
        const text = document.getElementById('copy-cmd-text');
        if (text) {
          text.textContent = 'Copied!';
          setTimeout(() => { text.textContent = 'Copy'; }, 2000);
        }
      });
    </script>
  </div>
</section>
