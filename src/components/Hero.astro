---
import { DotMatrixBg } from './ui/dot-matrix-bg';
---

<section class="relative pt-28 pb-20 md:pt-36 md:pb-28 overflow-hidden">
  <!-- Dot matrix background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <DotMatrixBg
      client:visible
      className="absolute inset-0 h-full w-full"
      colors={[[110, 118, 129], [63, 185, 80]]}
      opacities={[0.3, 0.3, 0.4, 0.5, 0.5, 0.6, 0.7, 0.8, 0.9, 1]}
      dotSize={4}
      totalSize={16}
      animationSpeed={5}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/40 to-bg/70"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,var(--color-bg)_75%)]"></div>
  </div>
  <div class="relative z-10 mx-auto max-w-6xl px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
      Currently in Beta &mdash; Apache 2.0 Licensed
    </div>

    <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-heading leading-tight tracking-tight mb-5">
      The open-source security<br/>
      automation ecosystem
    </h1>

    <p class="text-base md:text-lg text-text max-w-2xl mx-auto mb-10 leading-relaxed">
      Automate alert triage, enrich threats with AI, and respond to incidents in seconds &mdash; all with Python. No vendor lock-in. No per-action billing.
    </p>

    <!-- Install -->
    <div class="mt-2">
      <p class="text-[11px] text-muted mb-2">Get started in seconds</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-2.5">
        <div class="flex items-center gap-3 bg-surface border border-border rounded-lg px-4 py-2.5">
          <span class="text-muted select-none shrink-0 text-sm font-mono">$</span>
          <code class="text-sm text-heading font-mono whitespace-nowrap">curl -fsSL https://opensoar.app/install.sh | sh</code>
        </div>
        <button
          id="copy-cmd-btn"
          type="button"
          class="inline-flex items-center gap-1.5 px-4 py-2.5 text-sm font-medium rounded-lg bg-heading text-bg hover:bg-heading/90 transition-colors cursor-pointer border-none"
        >
          <svg id="copy-icon" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <span id="copy-cmd-text">Copy</span>
        </button>
      </div>
      <p class="text-[11px] text-muted mt-2.5">
        Or read the <a href="https://github.com/opensoar-hq/opensoar-core#quick-start" target="_blank" rel="noopener" class="text-heading hover:underline">documentation</a>
      </p>
    </div>

    <script is:inline>
      function copyText(str) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(str);
        } else {
          var ta = document.createElement('textarea');
          ta.value = str;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
      }
      document.addEventListener('DOMContentLoaded', function() {
        var btn = document.getElementById('copy-cmd-btn');
        if (btn) {
          btn.addEventListener('click', function() {
            copyText('curl -fsSL https://opensoar.app/install.sh | sh');
            var text = document.getElementById('copy-cmd-text');
            var icon = document.getElementById('copy-icon');
            if (text) text.textContent = 'Copied!';
            if (icon) icon.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
            setTimeout(function() {
              if (text) text.textContent = 'Copy';
              if (icon) icon.innerHTML = '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>';
            }, 2000);
          });
        }
      });
    </script>
  </div>
</section>
