---
---

<section class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-14">
      <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">Use Cases</span>
      <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-3">
        If it generates alerts,<br/>OpenSOAR can automate it
      </h2>
      <p class="text-sm text-text max-w-2xl mx-auto">
        Built for security teams. Works for anyone drowning in alerts.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      <!-- Security Operations -->
      <div class="rounded-lg border border-border bg-surface p-6 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex items-center justify-center w-9 h-9 rounded-lg bg-danger/10">
            <svg class="w-4.5 h-4.5 text-danger" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-heading">Security Operations</h3>
            <p class="text-[11px] text-muted">SOC teams, MSSPs, incident response</p>
          </div>
        </div>
        <ul class="space-y-2 text-xs text-text">
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Auto-triage SIEM alerts with threat intel enrichment</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Contain threats in seconds &mdash; isolate hosts, block IPs, disable accounts</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Phishing response: extract IOCs, quarantine emails, block senders</span>
          </li>
        </ul>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">CrowdStrike</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">Elastic</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">VirusTotal</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">Slack</span>
        </div>
      </div>

      <!-- IT Operations -->
      <div class="rounded-lg border border-border bg-surface p-6 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex items-center justify-center w-9 h-9 rounded-lg bg-warning/10">
            <svg class="w-4.5 h-4.5 text-warning" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-heading">IT Operations</h3>
            <p class="text-[11px] text-muted">SRE, infrastructure, on-call</p>
          </div>
        </div>
        <ul class="space-y-2 text-xs text-text">
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Auto-remediate infrastructure alerts &mdash; restart services, scale resources</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Runbook automation that's actually testable and version-controlled</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Reduce on-call fatigue by auto-resolving known patterns</span>
          </li>
        </ul>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">PagerDuty</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">Datadog</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">AWS</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">Jira</span>
        </div>
      </div>

      <!-- DevOps / Platform -->
      <div class="rounded-lg border border-border bg-surface p-6 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex items-center justify-center w-9 h-9 rounded-lg bg-success/10">
            <svg class="w-4.5 h-4.5 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-heading">DevOps & Platform</h3>
            <p class="text-[11px] text-muted">CI/CD, deployments, cloud ops</p>
          </div>
        </div>
        <ul class="space-y-2 text-xs text-text">
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Auto-rollback failed deployments based on health check alerts</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Coordinate cross-service incident response with explicit playbook sequencing</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Cost anomaly detection and automated scaling responses</span>
          </li>
        </ul>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">GitHub</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">Kubernetes</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">Terraform</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">Slack</span>
        </div>
      </div>

      <!-- Compliance -->
      <div class="rounded-lg border border-border bg-surface p-6 hover:border-border/80 transition-colors">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex items-center justify-center w-9 h-9 rounded-lg bg-info/10">
            <svg class="w-4.5 h-4.5 text-info" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-heading">Compliance & Audit</h3>
            <p class="text-[11px] text-muted">GRC, evidence collection, reporting</p>
          </div>
        </div>
        <ul class="space-y-2 text-xs text-text">
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Automated evidence collection for SOC 2, GDPR, HIPAA audits</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Every automation action logged with timestamps and full context</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-muted mt-0.5">&bull;</span>
            <span>Keep incident comments, timeline activity, and observables reviewable in one place</span>
          </li>
        </ul>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">ServiceNow</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">Jira</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">Email</span>
          <span class="px-2 py-0.5 rounded text-[10px] font-mono bg-bg border border-border text-muted">S3</span>
        </div>
      </div>
    </div>
  </div>
</section>
