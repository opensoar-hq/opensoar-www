---
---

<section id="playbooks" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <!-- Left: Description -->
      <div>
        <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">Developer Experience</span>
        <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-5">
          Playbooks that feel like<br/>writing real code
        </h2>
        <p class="text-sm text-text leading-relaxed mb-5">
          Because they <em>are</em> real code. Define triggers with decorators,
          enrich data with async/await, escalate with function calls.
          No proprietary DSL to learn, no visual flowcharts to untangle.
        </p>
        <ul class="space-y-2.5 text-sm text-text">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Type hints, autocomplete, linting &mdash; your IDE just works</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Unit test playbooks with pytest like any other code</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Version control, code review, CI/CD &mdash; standard workflows</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Async-first &mdash; enrich from 10 APIs in parallel, not sequentially</span>
          </li>
        </ul>
      </div>

      <!-- Right: Code block -->
      <div class="rounded-lg border border-border bg-surface overflow-hidden">
        <!-- Title bar -->
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-border">
          <div class="flex items-center gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-danger/50"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-warning/50"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-success/50"></div>
          </div>
          <span class="text-[11px] text-muted font-mono">triage_critical.py</span>
          <div class="w-14"></div>
        </div>

        <!-- Code -->
        <div class="p-4 overflow-x-auto">
          <pre class="text-xs leading-relaxed font-mono"><code><span class="text-danger/80">from</span> <span class="text-heading">opensoar</span> <span class="text-danger/80">import</span> <span class="text-heading">playbook, action</span>

<span class="text-danger/80">@action</span><span class="text-muted">(</span><span class="text-heading">name</span><span class="text-muted">=</span><span class="text-success">"enrich_ip"</span><span class="text-muted">,</span> <span class="text-heading">timeout</span><span class="text-muted">=</span><span class="text-warning">30</span><span class="text-muted">,</span> <span class="text-heading">retries</span><span class="text-muted">=</span><span class="text-warning">2</span><span class="text-muted">)</span>
<span class="text-danger/80">async def</span> <span class="text-heading">enrich_ip</span><span class="text-muted">(</span><span class="text-heading">ip</span><span class="text-muted">:</span> <span class="text-heading">str</span><span class="text-muted">)</span> <span class="text-muted">-></span> <span class="text-heading">dict</span><span class="text-muted">:</span>
    <span class="text-danger/80">return await</span> <span class="text-heading">virustotal</span><span class="text-muted">.</span><span class="text-heading">lookup_ip</span><span class="text-muted">(</span><span class="text-heading">ip</span><span class="text-muted">)</span>

<span class="text-danger/80">@playbook</span><span class="text-muted">(</span>
    <span class="text-heading">trigger</span><span class="text-muted">=</span><span class="text-success">"webhook"</span><span class="text-muted">,</span>
    <span class="text-heading">conditions</span><span class="text-muted">=&#123;</span><span class="text-success">"severity"</span><span class="text-muted">: [</span><span class="text-success">"high"</span><span class="text-muted">,</span> <span class="text-success">"critical"</span><span class="text-muted">]&#125;</span>
<span class="text-muted">)</span>
<span class="text-danger/80">async def</span> <span class="text-heading">triage_critical</span><span class="text-muted">(</span><span class="text-heading">alert</span><span class="text-muted">):</span>
    <span class="text-muted italic"># Enrich all IPs in parallel</span>
    <span class="text-heading">iocs</span> <span class="text-muted">=</span> <span class="text-heading">alert</span><span class="text-muted">.</span><span class="text-text">get</span><span class="text-muted">(</span><span class="text-success">"iocs"</span><span class="text-muted">,</span> <span class="text-muted">&#123;&#125;)</span>
    <span class="text-heading">results</span> <span class="text-muted">=</span> <span class="text-danger/80">await</span> <span class="text-heading">asyncio</span><span class="text-muted">.</span><span class="text-heading">gather</span><span class="text-muted">(</span>
        <span class="text-muted">*[</span><span class="text-heading">enrich_ip</span><span class="text-muted">(</span><span class="text-heading">ip</span><span class="text-muted">)</span> <span class="text-danger/80">for</span> <span class="text-heading">ip</span> <span class="text-danger/80">in</span> <span class="text-heading">iocs</span><span class="text-muted">.</span><span class="text-text">get</span><span class="text-muted">(</span><span class="text-success">"ips"</span><span class="text-muted">,</span> <span class="text-muted">[])]</span>
    <span class="text-muted">)</span>

    <span class="text-muted italic"># Auto-escalate if confirmed malicious</span>
    <span class="text-danger/80">if</span> <span class="text-heading">any</span><span class="text-muted">(</span><span class="text-heading">r</span><span class="text-muted">.</span><span class="text-text">get</span><span class="text-muted">(</span><span class="text-success">"malicious"</span><span class="text-muted">)</span> <span class="text-danger/80">for</span> <span class="text-heading">r</span> <span class="text-danger/80">in</span> <span class="text-heading">results</span><span class="text-muted">):</span>
        <span class="text-danger/80">await</span> <span class="text-heading">notify_soc</span><span class="text-muted">(</span><span class="text-success">f"Confirmed: &#123;</span><span class="text-heading">alert</span><span class="text-muted">[</span><span class="text-success">'title'</span><span class="text-muted">]</span><span class="text-success">&#125;"</span><span class="text-muted">)</span></code></pre>
        </div>
      </div>
    </div>
  </div>
</section>
