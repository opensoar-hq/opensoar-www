---
---

<section id="ai" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Visual showing AI flow -->
      <div class="order-2 lg:order-1">
        <div class="rounded-lg border border-border bg-surface overflow-hidden">
          <!-- Header -->
          <div class="flex items-center justify-between px-5 py-3 border-b border-border">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-heading" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a4 4 0 0 1 4 4c0 1.5-.8 2.8-2 3.5v1h-4v-1c-1.2-.7-2-2-2-3.5a4 4 0 0 1 4-4z"/>
                <path d="M10 10.5v2.5h4v-2.5"/>
                <path d="M10 13c-2.67.5-5 2-5 4v1h14v-1c0-2-2.33-3.5-5-4"/>
                <circle cx="12" cy="6" r="1"/>
              </svg>
              <span class="text-xs font-medium text-heading">AI Triage Engine</span>
            </div>
            <span class="text-heading bg-heading/10 px-2 py-0.5 rounded text-[10px] font-medium">Coming Soon</span>
          </div>

          <!-- Alert being analyzed -->
          <div class="p-5 space-y-4">
            <!-- Input alert -->
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-danger/15 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-danger" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-xs font-medium text-heading">Incoming Alert</div>
                <div class="text-[11px] text-muted mt-0.5">"Multiple failed SSH login attempts from 45.33.32.156 targeting root on prod-db-01"</div>
              </div>
            </div>

            <!-- Arrow -->
            <div class="flex justify-center">
              <svg class="w-4 h-4 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
            </div>

            <!-- AI analysis steps -->
            <div class="border border-border rounded-md bg-bg/50 p-4 space-y-3">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                <span class="text-[11px] text-text">Classified as <strong class="text-heading">Brute Force Attack</strong> with 97% confidence</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                <span class="text-[11px] text-text">Severity auto-raised from <span class="text-warning">medium</span> to <span class="text-danger">high</span> &mdash; targets production database</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                <span class="text-[11px] text-text">Correlated with <strong class="text-heading">3 related alerts</strong> from the same source IP</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                <span class="text-[11px] text-text">Deduplicated &mdash; <span class="text-muted">847 events</span> → <strong class="text-heading">1 incident</strong></span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                <span class="text-[11px] text-text">Recommended action: <strong class="text-heading">Block IP + escalate to on-call</strong></span>
              </div>
            </div>

            <!-- Arrow -->
            <div class="flex justify-center">
              <svg class="w-4 h-4 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
            </div>

            <!-- Output -->
            <div class="flex items-center gap-3 bg-success/5 border border-success/20 rounded-md px-4 py-3">
              <svg class="w-4 h-4 text-success flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <div>
                <div class="text-xs font-medium text-heading">Auto-triaged in 1.2s</div>
                <div class="text-[10px] text-muted">Playbook triggered, IP blocked, SOC notified via Slack</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Copy -->
      <div class="order-1 lg:order-2">
        <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">AI-Powered</span>
        <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-4">
          90% less noise.<br/>Zero alert fatigue.
        </h2>
        <p class="text-sm text-text leading-relaxed mb-6">
          LLM-powered triage classifies, deduplicates, and correlates alerts before they reach your analysts. Human-in-the-loop controls mean you stay in charge &mdash; AI handles the volume, your team handles the decisions.
        </p>
        <ul class="space-y-3 text-sm text-text">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Auto-classify alerts by attack type, technique, and severity</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Correlate related events into single incidents automatically</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Suggest response actions based on threat context and playbook history</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Bring your own LLM &mdash; OpenAI, Anthropic, or local models via Ollama</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
