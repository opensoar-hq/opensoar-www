---
import { AlertDisplayCards } from './AlertCards';
---

<section id="ai" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Animated alert cards with AI triage -->
      <div class="order-2 lg:order-1">
        <AlertDisplayCards client:visible />
      </div>

      <!-- Right: Copy -->
      <div class="order-1 lg:order-2">
        <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">AI-Powered</span>
        <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-4">
          90% less noise.<br/>Zero alert fatigue.
        </h2>
        <p class="text-sm text-text leading-relaxed mb-6">
          LLM-powered triage classifies, deduplicates, and correlates alerts before they reach your analysts. Human-in-the-loop controls mean you stay in charge &mdash; AI handles the volume, your team handles the decisions.
        </p>
        <ul class="space-y-3 text-sm text-text">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Auto-classify alerts by attack type, technique, and severity</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Correlate related events into single incidents automatically</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Suggest response actions based on threat context and playbook history</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-success mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Bring your own LLM &mdash; OpenAI, Anthropic, or local models via Ollama</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
