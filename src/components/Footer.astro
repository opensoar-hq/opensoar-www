---
---

<footer class="border-t border-white/5 py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-accent-blue to-accent-purple flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <span class="text-sm font-semibold text-white">OpenSOAR</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-slate-500">
        <a href="https://github.com/opensoar-hq" target="_blank" rel="noopener" class="hover:text-slate-300 transition-colors">GitHub</a>
        <a href="https://demo.opensoar.app" target="_blank" rel="noopener" class="hover:text-slate-300 transition-colors">Demo</a>
        <span class="text-slate-600 cursor-default" title="Coming soon">Docs</span>
      </div>

      <!-- Copyright -->
      <p class="text-sm text-slate-600">
        &copy; {new Date().getFullYear()} OpenSOAR. Apache 2.0 License.
      </p>
    </div>
  </div>
</footer>
