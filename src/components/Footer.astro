---
---

<footer class="border-t border-border py-10">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-5">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-lg bg-accent flex items-center justify-center">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </div>
        <span class="text-sm font-semibold text-heading">OpenSOAR</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-5 text-sm text-muted">
        <a href="https://github.com/opensoar-hq" target="_blank" rel="noopener" class="hover:text-heading transition-colors">GitHub</a>
        <a href="https://demo.opensoar.app" target="_blank" rel="noopener" class="hover:text-heading transition-colors">Demo</a>
        <span class="text-muted cursor-default" title="Coming soon">Docs</span>
      </div>

      <!-- Copyright -->
      <p class="text-[11px] text-muted">
        &copy; {new Date().getFullYear()} OpenSOAR. Apache 2.0 License.
      </p>
    </div>
  </div>
</footer>
