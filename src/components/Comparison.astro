---
const rows = [
  { feature: "Open Source", opensoar: true, shuffle: true, turbine: false, splunk: false, xsoar: false },
  { feature: "Python-Native Playbooks", opensoar: true, shuffle: false, turbine: "Sandboxed", splunk: false, xsoar: false },
  { feature: "No Per-Action Billing", opensoar: true, shuffle: true, turbine: false, splunk: false, xsoar: false },
  { feature: "Self-Hosted", opensoar: true, shuffle: true, turbine: true, splunk: true, xsoar: false },
  { feature: "AI-Ready Architecture", opensoar: true, shuffle: false, turbine: "Partial", splunk: "Partial", xsoar: "Partial" },
  { feature: "No Vendor Lock-In", opensoar: true, shuffle: true, turbine: false, splunk: false, xsoar: false },
  { feature: "Async / Parallel Execution", opensoar: true, shuffle: false, turbine: true, splunk: true, xsoar: true },
  { feature: "Apache 2.0 License", opensoar: true, shuffle: false, turbine: false, splunk: false, xsoar: false },
];

function renderCell(value: boolean | string) {
  if (value === true) return { icon: "check", color: "text-success" };
  if (value === false) return { icon: "x", color: "text-muted" };
  return { icon: "partial", color: "text-warning", text: value };
}
---

<section id="compare" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-12">
      <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs">Comparison</span>
      <h2 class="text-2xl md:text-3xl font-bold text-heading mt-4 mb-3">
        How OpenSOAR stacks up
      </h2>
      <p class="text-sm text-text max-w-2xl mx-auto">
        Compared to commercial SOAR platforms and open-source alternatives.
      </p>
    </div>

    <div class="rounded-lg border border-border bg-surface overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left px-5 py-3 text-muted font-medium text-xs"></th>
              <th class="px-5 py-3 text-center">
                <span class="text-heading bg-heading/10 px-2 py-0.5 rounded text-xs" style="font-family: 'Inter Tight', sans-serif; letter-spacing: -0.02em;"><span style="font-weight: 400;">Open</span><span style="font-weight: 700;">SOAR</span></span>
              </th>
              <th class="px-5 py-3 text-center text-muted font-medium text-xs">Shuffle</th>
              <th class="px-5 py-3 text-center text-muted font-medium text-xs">Turbine</th>
              <th class="px-5 py-3 text-center text-muted font-medium text-xs">Splunk SOAR</th>
              <th class="px-5 py-3 text-center text-muted font-medium text-xs">XSOAR</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row, i) => {
              const cells = [
                renderCell(row.opensoar),
                renderCell(row.shuffle),
                renderCell(row.turbine),
                renderCell(row.splunk),
                renderCell(row.xsoar),
              ];
              return (
                <tr class={`border-b border-border ${i % 2 === 0 ? 'bg-surface' : 'bg-bg'}`}>
                  <td class="px-5 py-3 text-heading font-medium text-sm">{row.feature}</td>
                  {cells.map((cell) => (
                    <td class="px-5 py-3 text-center">
                      {cell.icon === "check" && (
                        <svg class={`w-4 h-4 mx-auto ${cell.color}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      )}
                      {cell.icon === "x" && (
                        <svg class={`w-4 h-4 mx-auto ${cell.color}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      )}
                      {cell.icon === "partial" && (
                        <span class={`text-xs font-medium ${cell.color}`}>{cell.text}</span>
                      )}
                    </td>
                  ))}
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
