---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import OpenSource from '../components/OpenSource.astro';
import Footer from '../components/Footer.astro';

const categories = [
  {
    name: "SIEMs",
    color: "#58a6ff",
    tools: [
      { name: "Elastic Security", desc: "Log management & detection" },
      { name: "Splunk", desc: "Enterprise security analytics" },
      { name: "Microsoft Sentinel", desc: "Cloud-native SIEM" },
      { name: "QRadar", desc: "IBM threat detection" },
    ],
  },
  {
    name: "EDR/XDR",
    color: "#f85149",
    tools: [
      { name: "CrowdStrike Falcon", desc: "Endpoint detection & response" },
      { name: "SentinelOne", desc: "Autonomous endpoint protection" },
      { name: "Microsoft Defender", desc: "XDR across endpoints & cloud" },
      { name: "Carbon Black", desc: "VMware endpoint security" },
    ],
  },
  {
    name: "Cloud Security",
    color: "#3fb950",
    tools: [
      { name: "AWS GuardDuty", desc: "AWS threat detection" },
      { name: "Azure Security Center", desc: "Azure workload protection" },
      { name: "GCP Security Command Center", desc: "Google Cloud security" },
    ],
  },
  {
    name: "Threat Intelligence",
    color: "#d2a8ff",
    tools: [
      { name: "VirusTotal", desc: "File & URL analysis" },
      { name: "AbuseIPDB", desc: "IP reputation lookups" },
      { name: "OTX (AlienVault)", desc: "Open threat exchange" },
      { name: "MISP", desc: "Threat intelligence sharing" },
    ],
  },
  {
    name: "Email Security",
    color: "#d29922",
    tools: [
      { name: "Proofpoint", desc: "Email threat protection" },
      { name: "Mimecast", desc: "Email security gateway" },
      { name: "Microsoft Defender for Office 365", desc: "Office 365 protection" },
    ],
  },
  {
    name: "Network",
    color: "#79c0ff",
    tools: [
      { name: "Suricata", desc: "Network IDS/IPS" },
      { name: "Zeek", desc: "Network traffic analysis" },
      { name: "Palo Alto", desc: "Next-gen firewall" },
      { name: "Fortinet", desc: "Network security platform" },
    ],
  },
  {
    name: "Identity",
    color: "#7ee787",
    tools: [
      { name: "Okta", desc: "Identity & access management" },
      { name: "Azure AD", desc: "Microsoft identity platform" },
      { name: "CrowdStrike Identity", desc: "Identity threat detection" },
    ],
  },
  {
    name: "Ticketing & Communication",
    color: "#ffa657",
    tools: [
      { name: "Jira", desc: "Issue tracking & workflows" },
      { name: "ServiceNow", desc: "IT service management" },
      { name: "Slack", desc: "Team messaging & alerts" },
      { name: "Microsoft Teams", desc: "Collaboration & notifications" },
      { name: "PagerDuty", desc: "Incident management & on-call" },
    ],
  },
  {
    name: "Monitoring & Observability",
    color: "#e3b341",
    tools: [
      { name: "Datadog", desc: "Infrastructure and application monitoring" },
      { name: "Grafana", desc: "Dashboards and alerting" },
      { name: "Prometheus", desc: "Metrics and alerting" },
      { name: "New Relic", desc: "Full-stack observability" },
    ],
  },
  {
    name: "Cloud Platforms",
    color: "#56d364",
    tools: [
      { name: "AWS", desc: "EC2, Lambda, CloudWatch, S3" },
      { name: "Google Cloud", desc: "GKE, Cloud Functions, Cloud Monitoring" },
      { name: "Azure", desc: "VMs, Functions, Monitor, Key Vault" },
    ],
  },
  {
    name: "DevOps & CI/CD",
    color: "#f0883e",
    tools: [
      { name: "GitHub", desc: "Actions, Issues, Webhooks" },
      { name: "GitLab", desc: "Pipelines, Issues, Webhooks" },
      { name: "Terraform", desc: "Infrastructure state and drift" },
      { name: "Kubernetes", desc: "Pod health, scaling, rollbacks" },
    ],
  },
  {
    name: "Custom",
    color: "#8b949e",
    tools: [
      { name: "Webhooks", desc: "HTTP callback integrations" },
      { name: "REST API", desc: "Connect any HTTP API" },
      { name: "Syslog", desc: "Standard log forwarding" },
      { name: "Python SDK", desc: "Build custom integrations" },
    ],
  },
];
---

<Layout title="Integrations: Connect Your Stack | OpenSOAR" description="OpenSOAR integrates with SIEMs, EDR, cloud platforms, monitoring, DevOps tools, ticketing, and more. Connect your entire stack with Python-native integrations.">
  <Nav />
  <main>
    <!-- Hero -->
    <section class="pt-28 pb-12 md:pt-36 md:pb-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="max-w-3xl">
          <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs mb-4 inline-block">Integrations</span>
          <h1 class="text-2xl md:text-3xl font-bold text-heading leading-tight tracking-tight mb-4">
            Connect Your Stack
          </h1>
          <p class="text-sm text-text leading-relaxed max-w-2xl">
            OpenSOAR connects to the tools your team already uses — security, monitoring, ticketing, communication, and any API.
          </p>
        </div>
      </div>
    </section>

    <!-- Integration count bar -->
    <section class="pb-10">
      <div class="mx-auto max-w-6xl px-6">
        <div class="flex flex-wrap items-center gap-4 text-xs text-muted">
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
            <span class="text-heading font-medium">{categories.reduce((acc, c) => acc + c.tools.length, 0)}</span> integrations
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-warning"></span>
            <span class="text-heading font-medium">{categories.length}</span> categories
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-info"></span>
            100% open source
          </span>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="pb-20 md:pb-28">
      <div class="mx-auto max-w-6xl px-6 space-y-12">

        {categories.map((category) => (
          <div>
            <div class="flex items-center gap-2.5 mb-4">
              <div class="w-1 h-5 rounded-full" style={`background-color: ${category.color}`}></div>
              <h2 class="text-sm font-semibold text-heading">{category.name}</h2>
              <span class="text-[11px] text-muted">{category.tools.length} integrations</span>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
              {category.tools.map((tool) => (
                <div class="group rounded-lg border border-border bg-surface p-3.5 hover:border-border/80 transition-colors">
                  <div class="flex items-start gap-3">
                    <div
                      class="flex items-center justify-center w-8 h-8 rounded-md shrink-0 text-xs font-bold"
                      style={`background-color: ${category.color}15; color: ${category.color}`}
                    >
                      {tool.name.charAt(0)}
                    </div>
                    <div class="min-w-0">
                      <div class="text-xs font-medium text-heading truncate">{tool.name}</div>
                      <div class="text-[11px] text-muted mt-0.5 leading-snug">{tool.desc}</div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}

        <!-- Custom integrations section -->
        <div class="rounded-lg border border-border bg-surface p-6 md:p-8">
          <div class="max-w-2xl">
            <h2 class="text-sm font-semibold text-heading mb-3">Build Your Own Integrations</h2>
            <p class="text-xs text-text leading-relaxed mb-4">
              Any tool with an API can be integrated into OpenSOAR in a few lines of Python. Integrations are standard Python classes — import any library, call any endpoint, parse any response format. No vendor SDK required, no sandbox limitations.
            </p>
            <div class="rounded-md bg-bg border border-border overflow-hidden">
              <div class="flex items-center gap-1.5 px-3 py-1.5 border-b border-border">
                <div class="w-2 h-2 rounded-full bg-danger/40"></div>
                <div class="w-2 h-2 rounded-full bg-warning/40"></div>
                <div class="w-2 h-2 rounded-full bg-success/40"></div>
                <span class="text-[10px] text-muted font-mono ml-1">custom_integration.py</span>
              </div>
              <pre class="px-3 py-2.5 text-[11px] leading-relaxed font-mono overflow-x-auto no-scrollbar"><code><span class="text-[#ff7b72]">from</span> <span class="text-[#ffa657]">opensoar.integrations</span> <span class="text-[#ff7b72]">import</span> Integration

<span class="text-[#ff7b72]">class</span> <span class="text-[#d2a8ff]">MyTool</span>(Integration):
    <span class="text-[#ff7b72]">async def</span> <span class="text-[#d2a8ff]">lookup</span>(self, indicator):
        resp = <span class="text-[#ff7b72]">await</span> self.http.get(
            <span class="text-[#a5d6ff]">f"https://api.mytool.com/v1/&#123;indicator&#125;"</span>
        )
        <span class="text-[#ff7b72]">return</span> resp.json()</code></pre>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="text-center pt-4">
          <p class="text-sm text-text mb-5">
            All integrations are open source. Contribute new ones or customize existing ones for your environment.
          </p>
          <div class="flex items-center justify-center gap-3">
            <a
              href="https://github.com/opensoar-hq/opensoar-core"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-4 py-2 text-xs font-medium rounded-md bg-heading text-bg hover:bg-heading/90 transition-colors"
            >
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Browse on GitHub
            </a>
            <a
              href="https://docs.opensoar.app/playbooks/overview/"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-medium rounded-md border border-border text-text hover:text-heading hover:border-heading/30 transition-colors"
            >
              Learn about playbooks
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>
        </div>

      </div>
    </section>

    <OpenSource />
  </main>
  <Footer />
</Layout>
