---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import LiveDemo from '../components/LiveDemo.astro';
import ExplorePaths from '../components/ExplorePaths.astro';
import WhatIsSoar from '../components/WhatIsSoar.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Features from '../components/Features.astro';
import CodeExample from '../components/CodeExample.astro';
import UseCases from '../components/UseCases.astro';
import AiTriage from '../components/AiTriage.astro';
import Comparison from '../components/Comparison.astro';
import OpenSource from '../components/OpenSource.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="OpenSOAR — Alert-to-Response Automation in Python | Open Source">
  <Nav />
  <main>
    <Hero />
    <LiveDemo />
    <div class="relative z-20 -mt-1 md:-mt-2 rounded-t-[28px] md:rounded-t-[40px] bg-[linear-gradient(180deg,rgba(255,255,255,0.18)_0%,rgba(255,255,255,0.10)_14%,rgba(255,255,255,0.04)_28%,var(--color-bg)_58%)] pt-8 md:pt-12 shadow-[0_-24px_90px_rgba(255,255,255,0.07)]">
      <WhatIsSoar />
    </div>
    <HowItWorks />
    <CodeExample />
    <Features />
    <UseCases />
    <AiTriage />
    <Comparison />
    <ExplorePaths />
    <OpenSource />
  </main>
  <Footer />
</Layout>
