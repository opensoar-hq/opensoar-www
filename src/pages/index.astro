---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import LiveDemo from '../components/LiveDemo.astro';
import ExplorePaths from '../components/ExplorePaths.astro';
import WhatIsSoar from '../components/WhatIsSoar.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Features from '../components/Features.astro';
import CodeExample from '../components/CodeExample.astro';
import UseCases from '../components/UseCases.astro';
import AiTriage from '../components/AiTriage.astro';
import Comparison from '../components/Comparison.astro';
import OpenSource from '../components/OpenSource.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="OpenSOAR — Alert-to-Response Automation in Python | Open Source">
  <Nav />
  <main>
    <Hero />
    <LiveDemo />
    <div class="relative z-20 -mt-10 md:-mt-14 pt-12 md:pt-16">
      <div class="rounded-t-[28px] md:rounded-t-[40px] bg-[linear-gradient(180deg,rgba(255,255,255,0.12)_0%,rgba(255,255,255,0.06)_16%,rgba(255,255,255,0.02)_30%,var(--color-bg)_56%)] overflow-hidden">
        <WhatIsSoar />
      </div>
    </div>
    <HowItWorks />
    <CodeExample />
    <Features />
    <UseCases />
    <AiTriage />
    <Comparison />
    <ExplorePaths />
    <OpenSource />
  </main>
  <Footer />
</Layout>
