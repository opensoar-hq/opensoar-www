---
import ContentLayout from '../layouts/ContentLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import { AnimatedTerminal } from '../components/AnimatedTerminal';

const playbookCode = `from opensoar import add_current_alert_comment, playbook, update_current_alert

@playbook(
    trigger="webhook",
    conditions={"severity": ["high", "critical"]},
    description="Enrich high-signal alerts and leave them ready for analyst follow-up",
)
async def enrich_and_decide(alert):
    reputation = await check_ip(alert.get("source_ip"))

    if reputation.get("malicious"):
        await update_current_alert(
            status="in_progress",
            determination="suspicious",
            reason="Escalated after IP enrichment",
        )
        await add_current_alert_comment(
            "Threat intel came back hot. Analyst follow-up required."
        )

    return {"reputation": reputation}`;

const testCode = `import pytest
from my_first_playbook import enrich_and_decide

@pytest.mark.asyncio
async def test_malicious_ip_marks_alert_for_follow_up(monkeypatch):
    async def fake_check_ip(ip):
        assert ip == "45.33.32.156"
        return {"malicious": True}

    monkeypatch.setattr("my_first_playbook.check_ip", fake_check_ip)

    result = await enrich_and_decide({"source_ip": "45.33.32.156"})

    assert result["reputation"]["malicious"] is True`;

const bootstrapCommand = `docker compose exec api opensoar-bootstrap-admin \\
  --username admin \\
  --password changeme \\
  --display-name "OpenSOAR Admin"`;

const nextSteps = [
  {
    title: "Docs: Playbooks",
    href: "https://docs.opensoar.app/playbooks/overview/",
    description: "Canonical playbook docs",
  },
  {
    title: "Incident Workflow",
    href: "https://docs.opensoar.app/incidents/overview/",
    description: "How alerts become working incidents",
  },
  {
    title: "AI Triage",
    href: "/ai-triage",
    description: "Add LLM-powered alert analysis",
  },
];
---

<ContentLayout
  title="Getting Started with OpenSOAR — Install, Write, Deploy in 60 Seconds"
  description="Install OpenSOAR, write your first security automation playbook in Python, test it, and deploy — all in one terminal session. Free and open source."
  badge="Getting Started"
  heading="Getting Started"
  subheading="A fast editorial walkthrough of what the first OpenSOAR experience feels like. For canonical setup and operational docs, use docs.opensoar.app."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Getting Started', href: '/getting-started' },
  ]}
>
  <p>
    Need the exact install and deployment path? <a href="https://docs.opensoar.app/getting-started/" target="_blank" rel="noopener">Go to the docs</a>.
  </p>

  <h2>1. Install</h2>
  <p>
    This is the shortest path to seeing the product live locally. The docs cover the full setup, verification, and operational details.
  </p>
  <AnimatedTerminal
    client:visible
    commands={["curl -fsSL https://opensoar.app/install.sh | sh"]}
    outputs={[
      { text: "Downloading OpenSOAR v0.5.0...", delay: 400 },
      { text: "Installing dependencies...", delay: 800 },
      { text: "Starting services (PostgreSQL, Redis, API, Worker)...", delay: 1200 },
      { text: "\u2713 OpenSOAR is running at http://localhost:3000", delay: 1600 },
    ]}
    title="terminal — install"
    height="200px"
  />
  <p>
    Then bootstrap the first local admin. Additional local accounts are created from Settings by that admin; public self-registration is off by default in core.
  </p>
  <CodeBlock code={bootstrapCommand} filename="bootstrap-admin.sh" />

  <h2>2. Write your first playbook</h2>
  <p>
    This is the core product idea in one screen: playbooks are plain Python, not visual blocks or YAML definitions.
  </p>
  <CodeBlock code={playbookCode} filename="my_first_playbook.py" />

  <h2>3. Test it</h2>
  <p>
    Because playbooks are real code, you can test them with pytest. This page is showing the shape of the workflow, not replacing the full docs.
  </p>
  <CodeBlock code={testCode} filename="test_playbook.py" />

  <h2>4. Deploy</h2>
  <p>
    In practice, deployment means shipping code and reloading the services that discover and run it. The detailed loading model is documented separately.
  </p>
  <AnimatedTerminal
    client:visible
    commands={["git add playbooks/", "git commit -m 'Add enrichment playbook'", "git push origin main", "docker compose restart api worker"]}
    outputs={[
      { text: "\u2713 Playbook code deployed. API and worker restarted.", delay: 400 },
    ]}
    title="terminal — deploy"
    height="180px"
  />
  <p>
    For the exact loading and sync behavior, see <a href="https://docs.opensoar.app/playbooks/loading-and-sync/" target="_blank" rel="noopener">the docs</a>.
  </p>

  <h2>Next steps</h2>
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3 my-6">
    {nextSteps.map((item) => (
      <a
        href={item.href}
        class="rounded-lg border border-border bg-surface p-5 transition-colors hover:border-heading/30"
      >
        <h3 class="text-base font-semibold text-heading mb-2">{item.title}</h3>
        <p class="text-sm text-text leading-relaxed">{item.description}</p>
      </a>
    ))}
  </div>
</ContentLayout>
