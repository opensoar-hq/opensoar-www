---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import OpenSource from '../components/OpenSource.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  badge?: string;
  heading: string;
  subheading?: string;
  canonical?: string;
  ogImage?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, badge, heading, subheading, canonical, ogImage, structuredData } = Astro.props;
---

<Layout title={title} description={description} canonical={canonical} ogImage={ogImage} structuredData={structuredData}>
  <Nav />
  <main>
    <!-- Hero section — matches homepage section spacing -->
    <section class="pt-28 pb-12 md:pt-36 md:pb-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="max-w-3xl">
          {badge && (
            <span class="text-heading bg-heading/10 px-2 py-0.5 rounded font-medium text-xs mb-4 inline-block">{badge}</span>
          )}
          <h1 class="text-2xl md:text-3xl font-bold text-heading leading-tight tracking-tight mb-4">
            {heading}
          </h1>
          {subheading && (
            <p class="text-sm text-text leading-relaxed max-w-2xl">
              {subheading}
            </p>
          )}
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="pb-20 md:pb-28">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid lg:grid-cols-[1fr_280px] gap-12">
          <!-- Main content -->
          <div class="prose-content min-w-0">
            <slot />
          </div>

          <!-- Sidebar -->
          <aside class="hidden lg:block">
            <div class="sticky top-24 space-y-4">
              <!-- Quick links card -->
              <div class="rounded-lg border border-border bg-surface p-4">
                <span class="text-[10px] font-medium text-muted uppercase tracking-wider">On this page</span>
                <nav class="mt-3 space-y-1.5 toc-nav">
                </nav>
              </div>

              <!-- Related links -->
              <div class="rounded-lg border border-border bg-surface p-4">
                <span class="text-[10px] font-medium text-muted uppercase tracking-wider">Resources</span>
                <div class="mt-3 space-y-2">
                  <a href="https://docs.opensoar.app" target="_blank" rel="noopener" class="flex items-center gap-2 text-xs text-text hover:text-heading transition-colors">
                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    Docs
                  </a>
                  <a href="https://github.com/opensoar-hq/opensoar-core" target="_blank" rel="noopener" class="flex items-center gap-2 text-xs text-text hover:text-heading transition-colors">
                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    GitHub
                  </a>
                  <a href="/guides" class="flex items-center gap-2 text-xs text-text hover:text-heading transition-colors">
                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    Guides
                  </a>
                  <a href="/blog" class="flex items-center gap-2 text-xs text-text hover:text-heading transition-colors">
                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H8a2 2 0 0 1-2-2V5"/><path d="M16 3H6a2 2 0 0 0-2 2v11"/><path d="M10 7h6"/><path d="M10 11h6"/><path d="M10 15h4"/></svg>
                    Blog
                  </a>
                  <a href="/compare" class="flex items-center gap-2 text-xs text-text hover:text-heading transition-colors">
                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                    Compare platforms
                  </a>
                  <a href="/guides/what-is-soar" class="flex items-center gap-2 text-xs text-text hover:text-heading transition-colors">
                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    What is SOAR?
                  </a>
                  <a href="/guides/python-security-playbooks" class="flex items-center gap-2 text-xs text-text hover:text-heading transition-colors">
                    <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                    Python playbooks
                  </a>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <OpenSource />
  </main>
  <Footer />
</Layout>

<script>
  // Auto-generate table of contents from h2 elements with scroll spy
  const tocNav = document.querySelector('.toc-nav');
  const h2s = document.querySelectorAll('.prose-content h2');

  if (tocNav && h2s.length > 0) {
    const linkMap = new Map<string, HTMLAnchorElement>();

    h2s.forEach((h2, i) => {
      const id = h2.textContent?.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || `section-${i}`;
      h2.id = id;

      const link = document.createElement('a');
      link.href = `#${id}`;
      link.textContent = h2.textContent || '';
      link.className = 'block text-xs text-text hover:text-heading transition-colors truncate pl-2 border-l-2 border-transparent';
      tocNav.appendChild(link);
      linkMap.set(id, link);
    });

    function setActive(id: string) {
      linkMap.forEach((link, linkId) => {
        if (linkId === id) {
          link.classList.remove('text-text', 'border-transparent');
          link.classList.add('text-heading', 'border-success');
        } else {
          link.classList.remove('text-heading', 'border-success');
          link.classList.add('text-text', 'border-transparent');
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: '0px 0px -60% 0px', threshold: 0 }
    );

    h2s.forEach((h2) => observer.observe(h2));
  }
</script>
