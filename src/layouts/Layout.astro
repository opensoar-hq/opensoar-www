---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Open-source SOAR platform for modern security teams. Python-native playbooks, AI-assisted triage, real-time alert ingestion." } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-bg">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d1117" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://opensoar.app" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-text font-sans min-h-screen antialiased text-sm leading-normal">
    <slot />
  </body>
</html>
