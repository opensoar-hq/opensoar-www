---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const defaultDescription = "OpenSOAR is an open-source security automation platform. Automate alert triage, enrich threats with AI, and build incident response playbooks in Python. Free, self-hosted, Apache 2.0.";

const {
  title,
  description = defaultDescription,
  canonical,
  ogImage = "/og/default.svg",
  structuredData,
} = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
const defaultStructuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "OpenSOAR",
  "applicationCategory": "SecurityApplication",
  "operatingSystem": "Linux, macOS, Windows (Docker)",
  "description": description,
  "url": "https://opensoar.app",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "license": "https://opensource.org/licenses/Apache-2.0",
  "author": {
    "@type": "Organization",
    "name": "OpenSOAR",
    "url": "https://opensoar.app"
  },
  "codeRepository": "https://github.com/opensoar-hq/opensoar-core",
  "programmingLanguage": "Python"
};
const structuredDataNodes = [
  defaultStructuredData,
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : []),
];
---

<!doctype html>
<html lang="en" class="bg-bg">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="OpenSOAR Blog RSS Feed" href="/rss.xml" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;700&display=swap" rel="stylesheet" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d1117" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="OpenSOAR" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {structuredDataNodes.map((node) => (
      <script type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-text font-sans min-h-screen antialiased text-sm leading-normal">
    <slot />
  </body>
</html>
